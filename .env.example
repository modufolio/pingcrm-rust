# Application Configuration
APP_NAME="PingCRM"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://127.0.0.1:3000

# Server Configuration
HOST=127.0.0.1
PORT=3000

# Database Configuration
# SQLite (default)
DATABASE_URL=sqlite://appkit.db
# OR for PostgreSQL:
# DATABASE_URL=postgres://username:password@localhost/pingcrm

# Security Configuration
# IMPORTANT: Change these secrets in production!
JWT_SECRET=your-secret-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production

# Session Storage
# Options: memory (development only) or redis (recommended for production)
SESSION_BACKEND=memory

# Redis Configuration (optional, required if SESSION_BACKEND=redis)
REDIS_URL=redis://127.0.0.1:6379

# Logging Configuration
# Log levels: trace, debug, info, warn, error
RUST_LOG=info,app=debug,appkit_core=debug

# TUS Upload Configuration (optional, overrides config/tus.toml)
# TUS_API_PATH=/tus
# TUS_MAX_SIZE=104857600
# TUS_UPLOAD_DIR=public/uploads/tus
